# Variável PORT substituída na subida (imagem oficial nginx + envsubst).
server {
  listen 0.0.0.0:${PORT};
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  location = /index.html {
    add_header Cache-Control "no-store, no-cache, must-revalidate" always;
    try_files /index.html =404;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
