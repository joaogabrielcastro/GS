# Banco
DATABASE_URL="postgresql://user:pass@localhost:5432/gs?schema=public"
DIRECT_URL="postgresql://user:pass@localhost:5432/gs?schema=public"

# Auth
JWT_SECRET="troque-por-segredo-longo-aleatorio"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=production
CORS_ORIGIN="https://seu-dominio.com"
TRUST_PROXY=1

# Uploads — OBRIGATÓRIO em produção: caminho absoluto + volume persistente
UPLOAD_PATH=/data/gs/uploads

# Limpeza automática de arquivos (padrão: DESLIGADO em produção)
UPLOAD_CLEANUP_ENABLED=false
# Se habilitar, só pastas listadas (checklist e occurrences são sempre protegidas)
UPLOAD_CLEANUP_FOLDERS=tires
UPLOAD_CLEANUP_RETENTION_DAYS=3650
UPLOAD_CLEANUP_INTERVAL_HOURS=24

# Cadastro público de motorista (padrão: desligado)
ALLOW_PUBLIC_REGISTER=false
